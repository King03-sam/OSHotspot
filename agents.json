{
  "schema_version": "1.0",
  "name": "OSHotspot",
  "version": "1.0.0",
  "creator": "OLOJEDE Samuel",
  "license": "Apache-2.0",
  "repository": "https://github.com/King03-sam/OSHotspot",
  "description": "Automatic Linux WiFi hotspot manager. Creates a virtual AP interface and configures routing, DHCP and NAT automatically using hostapd, dnsmasq, iw, and iptables/nftables.",

  "purpose": {
    "problem": "Create a reliable WiFi hotspot when Linux NetworkManager hotspot sharing fails.",
    "solution": "Creates a virtual AP interface (ap0) and configures routing, DHCP and NAT automatically. Works alongside NetworkManager without disabling it.",
    "use_cases": [
      "Share WiFi from laptop to phone",
      "Create a temporary hotspot in hotels/cafes",
      "Replace broken NetworkManager hotspot"
    ]
  },

  "requirements": {
    "os": ["Linux"],
    "kernel": ">= 4.0 (nl80211 support)",
    "packages": [
      "hostapd",
      "dnsmasq",
      "iw",
      "iptables OR nftables",
      "iproute2",
      "qrencode"
    ],
    "permissions": "root (sudo)",
    "hardware": "WiFi adapter with AP mode support (check: iw list | grep '* AP')"
  },

  "installation": {
    "one_liner": "curl -fsSL https://raw.githubusercontent.com/King03-sam/OSHotspot/main/install.sh | sudo bash",
    "manual": "git clone https://github.com/King03-sam/OSHotspot.git && cd OSHotspot && sudo ./install.sh"
  },

  "configuration": {
    "file": "/etc/oshotspot/config.conf",
    "permissions": "600 (root only)",
    "parameters": {
      "SSID": { "type": "string", "required": true, "default": "OSHotspot", "max_length": 32 },
      "PASSWORD": { "type": "string", "required": true, "min_length": 8 },
      "CHANNEL": { "type": "int", "default": 6, "range": "1-13" },
      "HW_MODE": { "type": "string", "default": "g", "options": ["g", "a"] },
      "COUNTRY_CODE": { "type": "string", "default": "FR" },
      "WIFI_IFACE": { "type": "string", "default": "", "description": "Auto-detected if empty" },
      "AP_IFACE": { "type": "string", "default": "ap0" },
      "SUBNET": { "type": "string", "default": "192.168.50.0" },
      "AP_IP": { "type": "string", "default": "192.168.50.1" }
    }
  },

  "commands": {
    "start": { "cmd": "sudo oshotspot start", "description": "Start the WiFi hotspot" },
    "stop": { "cmd": "sudo oshotspot stop", "description": "Stop the WiFi hotspot" },
    "restart": { "cmd": "sudo oshotspot restart", "description": "Restart the hotspot" },
    "status": { "cmd": "sudo oshotspot status", "description": "Show hotspot status" },
    "repair": { "cmd": "sudo oshotspot repair", "description": "Repair after suspend/resume" },
    "clients": { "cmd": "sudo oshotspot clients", "description": "Show connected clients" },
    "monitor": { "cmd": "sudo oshotspot monitor", "description": "Real-time monitoring" },
    "qr": { "cmd": "sudo oshotspot qr", "description": "Show QR code to connect phone" },
    "doctor": { "cmd": "sudo oshotspot doctor", "description": "Run diagnostic checks" },
    "interfaces": { "cmd": "sudo oshotspot interfaces", "description": "List WiFi adapters" },
    "config": { "cmd": "sudo oshotspot config", "description": "Show current config" },
    "set": { "cmd": "sudo oshotspot set <key> <value>", "description": "Change config (ssid, password, wifi_iface)" }
  },

  "network": {
    "architecture": "Client -> ap0 (192.168.50.1) -> NAT -> WiFi_IFACE -> Internet",
    "ap_interface": "ap0 (virtual, created via iw)",
    "default_gateway": "192.168.50.1",
    "dhcp_range": "192.168.50.10 - 192.168.50.100",
    "dhcp_lease": "12h",
    "dns": ["8.8.8.8", "1.1.1.1"],
    "firewall": "iptables MASQUERADE or nftables masquerade",
    "ip_forward": "net.ipv4.ip_forward=1"
  },

  "file_structure": {
    "cli": "oshotspot",
    "scripts": "scripts/{utils,firewall,start,stop,repair,status,clients,monitor,qr,doctor}.sh",
    "configs": "configs/{hostapd.conf.template,dnsmasq.conf.template,nm-oshotspot.conf}",
    "systemd": "systemd/{oshotspot.service,oshotspot-dnsmasq.service}",
    "completions": "completions/oshotspot"
  },

  "troubleshooting": {
    "no_internet": "Check: sudo oshotspot status -> verify NAT is ACTIVE. Run: sudo oshotspot repair",
    "clients_cant_connect": "Check: sudo oshotspot doctor -> verify AP mode supported. Check password in config.",
    "hostapd_fails": "Check: sudo journalctl -u oshotspot. Ensure no other hostapd is running.",
    "no_wifi_detected": "Run: sudo oshotspot interfaces. Set manually: sudo oshotspot set wifi_iface wlan0"
  }
}
