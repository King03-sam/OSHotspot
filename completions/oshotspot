# Bash completion for oshotspot

_oshotspot() {
    local cur prev commands set_commands
    COMPREPLY=()
    cur="${COMP_WORDS[COMP_CWORD]}"
    prev="${COMP_WORDS[COMP_CWORD-1]}"

    commands="start stop restart repair status clients monitor config qr doctor interfaces logs web enable disable set help"

    if [[ ${COMP_CWORD} -eq 1 ]]; then
        COMPREPLY=($(compgen -W "${commands}" -- "${cur}"))
        return 0
    fi

    case "${COMP_WORDS[1]}" in
        set)
            if [[ ${COMP_CWORD} -eq 2 ]]; then
                set_commands="ssid password wifi_iface"
                COMPREPLY=($(compgen -W "${set_commands}" -- "${cur}"))
            fi
            return 0
            ;;
    esac
}

complete -F _oshotspot oshotspot
